    elseif par:IsA("Model") then local pr=par.PrimaryPart or par:FindFirstChildWhichIsA("BasePart"); return pr and pr.Position
    elseif par:IsA("Attachment") then return par.WorldPosition
    else local pt=par:FindFirstChildWhichIsA("BasePart",true); return pt and pt.Position end
end
local function findNearestStealPrompt()
    local c=player.Character; local root=c and c:FindFirstChild("HumanoidRootPart"); if not root then return nil end
    local plots=workspace:FindFirstChild("Plots"); if not plots then return nil end
    local np,nd=nil,math.huge
    for _,plot in ipairs(plots:GetChildren()) do
        for _,obj in ipairs(plot:GetDescendants()) do
            if obj:IsA("ProximityPrompt") and obj.Enabled and obj.ActionText=="Steal" then
                local pos=getPromptPos(obj); if pos then local d=(root.Position-pos).Magnitude; if d<=STEAL_RADIUS and d<nd then np=obj; nd=d end end
