-- Walk Fling
local _wfConns={}; local _wfActive=false
local function startWalkFling()
    _wfActive=true
    table.insert(_wfConns,RunService.Stepped:Connect(function()
        if not _wfActive then return end
        for _,p in ipairs(Players:GetPlayers()) do
            if p~=player and p.Character then for _,part in ipairs(p.Character:GetChildren()) do if part:IsA("BasePart") then part.CanCollide=false end end end
        end
    end))
    local co=coroutine.create(function()
        while _wfActive do
            RunService.Heartbeat:Wait(); local char=player.Character; local root=char and char:FindFirstChild("HumanoidRootPart")
            if not root then RunService.Heartbeat:Wait(); continue end
            local vel=root.Velocity; root.Velocity=vel*10000+Vector3.new(0,10000,0)
            RunService.RenderStepped:Wait(); if root and root.Parent then root.Velocity=vel end
            RunService.Stepped:Wait(); if root and root.Parent then root.Velocity=vel+Vector3.new(0,0.1,0) end
        end
    end)
    coroutine.resume(co); table.insert(_wfConns,co)
end
local function stopWalkFling()
    _wfActive=false
    for _,c in ipairs(_wfConns) do
        if typeof(c)=="RBXScriptConnection" then c:Disconnect() elseif typeof(c)=="thread" then pcall(task.cancel,c) end
    end; _wfConns={}
end

-- Aimbot
local function findNearestEnemy(myHRP)
    local nearest,nd,nHead=nil,math.huge,nil
    for _,p in ipairs(Players:GetPlayers()) do
        if p~=player and p.Character then
            local eh   = p.Character:FindFirstChild("HumanoidRootPart")
            local head = p.Character:FindFirstChild("Head")
            local hum  = p.Character:FindFirstChildOfClass("Humanoid")
            if eh and hum and hum.Health>0 then
                local d=(eh.Position-myHRP.Position).Magnitude
                if d<nd and d<=AimbotRadius then nd=d; nearest=eh; nHead=head or eh end
            end
        end
    end
    return nearest,nd,nHead
end

local function startBatAimbot()
    if batAimbotConn then return end
    batAimbotConn = RunService.Heartbeat:Connect(function()
        if not batAimbotActive then return end
        local c = player.Character; if not c then return end
        local h = c:FindFirstChild("HumanoidRootPart"); if not h then return end
        local target, dist = findNearestEnemy(h)
        if not target then return end
        -- Fly to front of target (K7 method)
        local forward  = target.CFrame.LookVector
        local frontPos = target.Position + forward * 1.5
        local direction = (frontPos - h.Position).Unit
        h.AssemblyLinearVelocity = Vector3.new(
            direction.X * BatAimbotSpeed,
            direction.Y * BatAimbotSpeed,
            direction.Z * BatAimbotSpeed
        )
        -- Hit when close
        if dist <= 5 then
            local tool = c:FindFirstChildOfClass("Tool")
            if tool then
                pcall(function() tool:Activate() end)
                local evt = tool:FindFirstChildWhichIsA("RemoteEvent")
                if evt then pcall(function() evt:FireServer() end) end
            end
        end
    end)
end
local function stopBatAimbot()
    if batAimbotConn then batAimbotConn:Disconnect(); batAimbotConn = nil end
    local c = player.Character
    if c then
        local hum = c:FindFirstChildOfClass("Humanoid")
        if hum then hum.AutoRotate = true end
    end
end
-- Counter Hit (ragdoll-based, first item only, no aimbot)
local function doCounterHit()
    if counterCooldown then return end; counterCooldown=true
    task.spawn(function()
        task.wait(0.2)
        local char=player.Character; if not char then counterCooldown=false; return end
        local hrp=char:FindFirstChild("HumanoidRootPart"); local hum=char:FindFirstChildOfClass("Humanoid")
        if not hrp or not hum then counterCooldown=false; return end
        local tool=getFirstTool()
        if tool and tool.Parent~=char then hum:EquipTool(tool); task.wait(0.08) end
        -- Find nearest enemy
        local nearest,nearestChar,nd=nil,nil,math.huge
        for _,p in ipairs(Players:GetPlayers()) do
            if p~=player and p.Character then
                local eh=p.Character:FindFirstChild("HumanoidRootPart"); local eh_hum=p.Character:FindFirstChildOfClass("Humanoid")
                if eh and eh_hum and eh_hum.Health>0 then
                    local d=(eh.Position-hrp.Position).Magnitude
                    if d<nd and d<70 then nd=d; nearest=eh; nearestChar=p.Character end
                end
            end
        end
        for _=1,3 do
            local tHum=nearestChar and nearestChar:FindFirstChildOfClass("Humanoid"); if not tHum or tHum.Health<=0 then break end
            char=player.Character; if not char then break end
            hrp=char:FindFirstChild("HumanoidRootPart"); if not hrp then break end
            if nearest then
                local dir=nearest.Position-hrp.Position
                if dir.Magnitude>0.5 then hrp.AssemblyLinearVelocity=dir.Unit*COUNTER_RUSH_SPEED end
