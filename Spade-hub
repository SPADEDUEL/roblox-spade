-- Jump Boost
-- Jump Boost Ã¢â‚¬â€ hooks JumpRequest so it only fires on actual jump press
-- Setting JumpPower in Heartbeat every frame causes the game to think
-- the character re-jumped, dropping held items. We only apply it once per press.
local function startJumpBoost()
    if jumpBoostConn then jumpBoostConn:Disconnect() end
    -- Apply once immediately so the next jump uses the new power
    local function applyPower()
        local hum = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
        if hum then hum.UseJumpPower = true; hum.JumpPower = JUMP_POWER_VALUE end
    end
    applyPower()
    jumpBoostConn = UIS.JumpRequest:Connect(function()
        if not jumpBoostActive then return end
        applyPower()
    end)
end
local function stopJumpBoost()
    if jumpBoostConn then jumpBoostConn:Disconnect(); jumpBoostConn=nil end
    local hum = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
    if hum then hum.UseJumpPower = true; hum.JumpPower = 50 end
end

-- Infinite Jump Ã¢â‚¬â€ uses velocity kick, NOT ChangeState (avoids reset)
local function startInfJump()
    if infJumpConn then infJumpConn:Disconnect() end
    infJumpConn=UIS.JumpRequest:Connect(function()
        if not infJumpActive then return end
        local char=player.Character; if not char then return end
        local hrp=char:FindFirstChild("HumanoidRootPart")
        local hum=char:FindFirstChildOfClass("Humanoid")
        if not hrp or not hum or hum.Health<=0 then return end
        -- Only jump again if airborne (not grounded)
        local onGround=hum.FloorMaterial~=Enum.Material.Air
        if not onGround then
            -- Kick upward using velocity Ã¢â‚¬â€ safe, no state change
            hrp.AssemblyLinearVelocity=Vector3.new(
                hrp.AssemblyLinearVelocity.X,
                math.max(hrp.AssemblyLinearVelocity.Y, 50),
                hrp.AssemblyLinearVelocity.Z
            )
        end
    end)
end
local function stopInfJump()
    if infJumpConn then infJumpConn:Disconnect(); infJumpConn=nil end
end

