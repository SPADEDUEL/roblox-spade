local function ensureMarkerFolder()
    if not markerFolder or not markerFolder.Parent then
        local old = workspace:FindFirstChild("SpadeWPMarkers")
        if old then old:Destroy() end
        markerFolder = Instance.new("Folder")
        markerFolder.Name = "SpadeWPMarkers"
        markerFolder.Parent = workspace
    end
end

local function createMarker(key, pos, color, labelText)
    ensureMarkerFolder()
    if waypointMarkers[key] and waypointMarkers[key].Parent then
        waypointMarkers[key]:Destroy()
    end
    local part = Instance.new("Part")
    part.Name="WP_"..key; part.Shape=Enum.PartType.Ball
    part.Size=Vector3.new(1.6,1.6,1.6); part.CFrame=CFrame.new(pos)
    part.Anchored=true; part.CanCollide=false; part.CastShadow=false
    part.Transparency=0.25; part.Color=color; part.Material=Enum.Material.Neon
    part.Parent=markerFolder
    local bb=Instance.new("BillboardGui",part)
    bb.Size=UDim2.new(0,54,0,22); bb.StudsOffset=Vector3.new(0,1.6,0)
    bb.AlwaysOnTop=true; bb.LightInfluence=0
    local lbl=Instance.new("TextLabel",bb)
    lbl.Size=UDim2.new(1,0,1,0); lbl.BackgroundColor3=color; lbl.BackgroundTransparency=0.08
    lbl.Text=labelText; lbl.TextColor3=Color3.fromRGB(255,255,255)
    lbl.Font=Enum.Font.GothamBold; lbl.TextSize=12; lbl.TextStrokeTransparency=0.3
    Instance.new("UICorner",lbl).CornerRadius=UDim.new(0,12)
    waypointMarkers[key]=part
end

