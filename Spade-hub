local function doSaveConfig()
    local data={toggles={},positions={},speeds={},waypoints={}}
    for name,reg in pairs(settingsRegistry) do data.toggles[name]=reg.getState() end
    data.toggles["GroundTPVisible"]=groundTPFloat.Visible
    for name,frame in pairs(positionFrames) do data.positions[name]=su(frame.Position) end
    data.speeds={normalSpeed=normalSGV(),carrySpeed=carrySGV(),jumpPower=jumpSGV(),stealRadius=stealRadGV(),stealInterval=stealSpdGV()}
    data.waypoints={right=rightWaypointData,left=leftWaypointData}
    local ok=pcall(writefile,CONFIG_FILE,HttpService:JSONEncode(data))
    if ok then
        TweenService:Create(SaveBtn,TweenInfo.new(0.1),{BackgroundColor3=Color3.fromRGB(0,200,80)}):Play(); SaveBtn.Text="Ã¢Å“â€  SAVED!"
        task.delay(1.2,function() TweenService:Create(SaveBtn,TweenInfo.new(0.2),{BackgroundColor3=C_SAVE}):Play(); SaveBtn.Text="Ã°Å¸â€™Â¾  SAVE CONFIG" end)
    else SaveBtn.Text="Ã¢Å“Ëœ  FAILED"; task.delay(1.5,function() SaveBtn.Text="Ã°Å¸â€™Â¾  SAVE CONFIG" end) end
end

local function doLoadConfig()
    local data=loadConfig(); if not data then return end
    if data.toggles then
        for name,state in pairs(data.toggles) do
            if name=="GroundTPVisible" then
                groundTPFloat.Visible=state; groundTPEnabled=state
                local reg=settingsRegistry["Ground TP"]; if reg then if state then reg.activate() else reg.deactivate() end end
            elseif settingsRegistry[name] then
                if state then settingsRegistry[name].activate() else settingsRegistry[name].deactivate() end
            end
        end
    end
    if data.positions then for name,pd in pairs(data.positions) do local frame=positionFrames[name]; if frame then local ok,u=pcall(du,pd); if ok then frame.Position=u end end end end
    if data.speeds then
        if data.speeds.normalSpeed   then normalSSV(data.speeds.normalSpeed) end
        if data.speeds.carrySpeed    then carrySSV(data.speeds.carrySpeed)   end
        if data.speeds.jumpPower     then jumpSSV(data.speeds.jumpPower)     end
        if data.speeds.stealRadius   then stealRadSV(data.speeds.stealRadius) end
        if data.speeds.stealInterval then stealSpdSV(data.speeds.stealInterval) end
    end
    if data.waypoints then
        local function restoreWP(wpData,targetData,side)
            if not wpData then return end
            for i,d in ipairs(wpData) do
                if targetData[i] then
                    targetData[i].x=d.x; targetData[i].y=d.y; targetData[i].z=d.z
                    local wf=waypointFields[side] and waypointFields[side][i]
                    if wf then wf["x"].Text=tostring(d.x); wf["y"].Text=tostring(d.y); wf["z"].Text=tostring(d.z) end
                end
            end
            if side=="right" then rightWaypoints=buildWaypoints(rightWaypointData)
            else leftWaypoints=buildWaypoints(leftWaypointData) end
        end
        restoreWP(data.waypoints.right,rightWaypointData,"right")
        restoreWP(data.waypoints.left, leftWaypointData, "left")
        if showWaypointsEnabled then showAllMarkers() end
    end
end

